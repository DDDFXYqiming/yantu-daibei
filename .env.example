# Android RevenueCat public SDK key. Keep this public key here; do not put private store keys in the app.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxx

# iOS key reserved for future App Store release.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxx

# During early development, keep mock purchases enabled so Expo Go / basic dev build can demo all flows.
# Set to false only after RevenueCat + Google Play product are configured and you use a development build.
EXPO_PUBLIC_USE_MOCK_PURCHASES=true
